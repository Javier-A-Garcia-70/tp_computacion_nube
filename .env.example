# Anthropic
ANTHROPIC_API_KEY=sk...

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa...
VOYAGE_MODEL=voyage-code-3

# PostgreSQL + pgvector (DigitalOcean Managed PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Leonardo AI (generación de imágenes para PDF — opcional)
LEONARDO_API_KEY=

# CORS backend (dominios permitidos, separados por coma)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,https://tu-frontend.vercel.app

# Frontend
REACT_APP_API_URL=https://<url-do-app-platform>/ask
